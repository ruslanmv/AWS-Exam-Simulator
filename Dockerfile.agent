FROM python:3.12-slim

WORKDIR /app

# Install MCP server (needed for direct import)
COPY mcp_server/ /app/mcp_server/
RUN pip install --no-cache-dir -e /app/mcp_server/

# Install agent runtime dependencies
COPY agent_runtime/ /app/agent_runtime/

# Copy question banks
COPY questions/ /data/questions/

ENV AWS_EXAM_QUESTION_DIR=/data/questions
ENV AWS_EXAM_DB_PATH=/data/state/aws_exam.sqlite
ENV USE_DIRECT_MCP=true
ENV AGENT_HOST=0.0.0.0
ENV AGENT_PORT=8080

EXPOSE 8080

CMD ["python", "/app/agent_runtime/start_agent.py", "--server"]
