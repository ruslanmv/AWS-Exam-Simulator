FROM python:3.12-slim

WORKDIR /app

# Install MCP server
COPY mcp_server/ /app/mcp_server/
RUN pip install --no-cache-dir -e /app/mcp_server/

# Copy question banks
COPY questions/ /data/questions/

ENV AWS_EXAM_QUESTION_DIR=/data/questions
ENV AWS_EXAM_DB_PATH=/data/state/aws_exam.sqlite

EXPOSE 9101

CMD ["aws-exam-tools"]
